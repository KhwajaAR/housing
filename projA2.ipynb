    "        data['Log Sale Price'] = np.log(data['Sale Price'])\n",
    "        data = remove_outliers(data, 'Log Sale Price', lower=6, upper=18)\n",
    "        data = remove_outliers(data, 'Sale Price', lower=500, upper=1000000)\n",
    "        # ... remove outliers for any columns in x matrix matrix\n",
    "    # else:\n",
    "        # Processing for the test set\n",
    "        # CANNOT involve references to sale price!\n",
    "        # CANNOT involve removing any rows\n",
    "        # ... \n",
    "        \n",
    "    # Processing for both test and training set\n",
    "    # CANNOT involve references to sale price!\n",
    "    # CANNOT involve removing any rows\n",
    "    # CAN involve applying log, sqrt, sq transformations to columns\n",
    "    data['Log Building Square Feet'] = np.log(data['Building Square Feet'])\n",
    "    data = add_total_bedrooms(data)\n",
    "    data = one_hot_encode(data, ['Construction Quality'])\n",
    "    data = one_hot_encode(data, ['Garage 1 Size'])\n",
    "    # data = one_hot_encode(data, [''])\n",
    "    \n",
    "    \n",
    "    # Return predictors (X) and response (Y) variables separately\n",
    "    if is_test_set:\n",
    "        # Predictors \n",
    "        X = data[['Log Building Square Feet','Bedrooms', 'Town Code', 'Construction Quality_1.0', 'Construction Quality_2.0',\n",
    "                  'Construction Quality_3.0', 'Garage 1 Size_0.0', 'Garage 1 Size_1.0','Garage 1 Size_2.0', 'Garage 1 Size_3.0', \n",
    "                  'Garage 1 Size_4.0', 'Garage 1 Size_5.0', 'Garage 1 Size_6.0', 'Garage 1 Size_7.0']]\n",
    "        return X\n",
