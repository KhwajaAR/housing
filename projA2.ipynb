    "        # Predictors. Your X should not include Log Sale Price!\n",
    "        X = data[['Log Building Square Feet','Bedrooms', 'Town Code', 'Construction Quality_1.0', 'Construction Quality_2.0',\n",
    "                  'Construction Quality_3.0', 'Garage 1 Size_0.0', 'Garage 1 Size_1.0','Garage 1 Size_2.0', 'Garage 1 Size_3.0', \n",
    "                  'Garage 1 Size_4.0', 'Garage 1 Size_5.0', 'Garage 1 Size_6.0', 'Garage 1 Size_7.0']]\n",
    "        # Response variable\n",
